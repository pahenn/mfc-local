# Copy this file to .env and fill in real values.
# .env is gitignored via the repo-root .gitignore (`**/.env`).

# ── MFC legacy MSSQL (for driven-brands-analytics extracts) ────────────────
# Ask the platform team for these. Production credentials live in 1Password /
# whatever secret store MFC is using — don't paste them here.

DB_SERVER=your-server.example.net
DB_DATABASE=your-database-name
DB_USER=your-username
DB_PASSWORD=your-password

# Optional — only needed if the defaults don't work
DB_PORT=1433
TDS_VERSION=7.4

# Set to true for Windows / Trusted auth (ignores DB_USER / DB_PASSWORD)
DB_USE_WINDOWS_AUTH=false
